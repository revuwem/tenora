{
  "name": "tenora",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --write",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "check": "turbo run check",
    "format": "turbo run format --log-order=grouped",
    "format:fix": "turbo run format --log-order=grouped -- --write",
    "docker:up": "docker compose up",
    "docker:up:detached": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
